# =============================================================================
# MSSQL Backup Manager Configuration
# =============================================================================
# Copy this file to .env and configure your settings

# -----------------------------------------------------------------------------
# SQL Server Connection (Source Server)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourPasswordHere
DB_DRIVER=ODBC Driver 17 for SQL Server

# -----------------------------------------------------------------------------
# Backup Paths
# -----------------------------------------------------------------------------
# Local path where backup files are stored/downloaded
BACKUP_PATH=./backups

# Server-side path for Docker/remote SQL Server (path INSIDE the container)
# Only set this if your SQL Server runs in Docker or on a remote server
# DB_BACKUP_SERVER_PATH=/var/opt/mssql/data/

# -----------------------------------------------------------------------------
# SSH Configuration (for Remote SQL Server in Docker)
# Set these to automatically download backups from remote Docker SQL Server
# -----------------------------------------------------------------------------
# SSH_HOST=your-server.com
# SSH_PORT=22
# SSH_USER=ubuntu
# SSH_PASSWORD=yourpassword
# SSH_KEY_FILE=/path/to/private/key  # Use this instead of SSH_PASSWORD
# DOCKER_CONTAINER=mssql             # Name of SQL Server Docker container

# -----------------------------------------------------------------------------
# Target Server Configuration (for cross-server restore)
# Set these if you want to restore backups to a DIFFERENT SQL Server instance
# If not set, defaults to source server SSH settings
# -----------------------------------------------------------------------------
# SSH_TARGET_HOST=target-server.com
# SSH_TARGET_PORT=22
# SSH_TARGET_USER=ubuntu
# SSH_TARGET_PASSWORD=yourpassword
# SSH_TARGET_KEY_FILE=/path/to/key
# DOCKER_TARGET_CONTAINER=mssql-target  # Docker container on target server
# DB_TARGET_BACKUP_PATH=/var/opt/mssql/data/  # Backup path on target server
